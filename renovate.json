{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "baseBranchPatterns": [
    "master",
    "main",
    "v1.7",
    "v1.8",
    "v1.9"
  ],
  "dependencyDashboard": false,
  "recreateWhen": "always",
  "osvVulnerabilityAlerts": true,
  "enabledManagers": [
    "gomod",
    "dockerfile",
    "github-actions",
    "pip_requirements"
  ],
  "extends": [
    "config:recommended",
    "security:only-security-updates",
    ":semanticCommitTypeAll(chore)",
    "mergeConfidence:age-confidence-badges",
    ":gitSignOff"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["needs-review"],
    "automerge": false
  },
  "reviewers": ["harvester/dev"],
  "ignorePaths": [
    "deploy/**",
    "**/charts/**"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "(^|/)Dockerfile$",
      "(^|/)Dockerfile\\.[^/]*$"
    ]
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Use dependencies label for real dependency updates",
      "matchManagers": ["gomod", "dockerfile", "pip_requirements"],
      "addLabels": ["dependencies"]
    },
    {
      "description": "Use ci scope for GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci"
    },
    {
      "description": "Release branches: only security",
      "matchBaseBranches": ["/^v\\d+(\\.\\d+)+/"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "description": "Disable Helm datasource updates",
      "enabled": false,
      "matchDatasources": ["helm"]
    },
    {
      "description": "Disable major updates for Go modules",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Disable github.com/rancher/lasso updates",
      "enabled": false,
      "matchManagers": ["gomod"],
      "matchPackageNames": ["github.com/rancher/lasso"]
    },
    {
      "description": "Disable longhorn packages",
      "enabled": false,
      "matchManagers": ["gomod"],
      "matchPackagePatterns": ["^github\\.com/longhorn/"]
    },
    {
      "description": "Disable kubevirt updates",
      "enabled": false,
      "matchManagers": ["gomod"],
      "matchPackagePatterns": ["^kubevirt\\.io/"]
    },
    {
      "description": "Group golang toolchain - go.mod",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchPackageNames": ["go"],
      "matchDepTypes": ["golang"],
      "groupName": "golang toolchain",
      "semanticCommitType": "deps",
      "semanticCommitScope": "go",
      "automerge": false,
      "rangeStrategy": "bump"
    },
    {
      "description": "Group golang toolchain - Dockerfile",
      "matchManagers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golang", "registry.suse.com/bci/golang"],
      "matchDepTypes": ["stage", "final"],
      "groupName": "golang toolchain",
      "semanticCommitType": "deps",
      "semanticCommitScope": "go",
      "automerge": false,
      "rangeStrategy": "bump"
    },
    {
      "description": "Allow vulnerability updates for indirect Go modules",
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "matchCategories": ["security"],
      "enabled": true
    },
    {
      "description": "Group all BCI base images together",
      "enabled": false,
      "matchManagers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "registry.suse.com/bci/**",
        "registry.opensuse.org/**",
        "!registry.suse.com/bci/golang"
      ],
      "groupName": "SUSE BCI base images",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "automerge": false,
      "rangeStrategy": "bump"
    },
    {
      "description": "Group k8s and rancher packages",
      "matchManagers": ["gomod"],
      "matchPackagePatterns": [
        "k8s\\.io/",
        "^github\\.com/rancher/",
        "^github\\.com/k3s-io/"
      ],
      "automerge": false,
      "groupName": "k8s + rancher dependencies",
      "prBodyNotes": ["⚠️ **Check longhorn compatibility before merging.**"]
    },
    {
      "description": "Label PRs with target branch name",
      "addLabels": ["renovate/{{baseBranch}}"]
    }
  ],
  "postUpdateOptions": ["gomodTidy", "gomodVendor"],
  "schedule": ["at any time"],
  "semanticCommitScope": "deps",
  "semanticCommitType": "chore",
  "semanticCommits": "enabled",
  "timezone": "Asia/Taipei"
}